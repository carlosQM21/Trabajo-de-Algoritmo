Funcion suma(num1,num2)
    Definir sumar Como Real
    sumar=0
    Si num1 > 0 y num2 > 0
        sumar = num1 + num2
        Escribir num1,"+",num2,"=",sumar
    SiNo
        Escribir "Los numeros deben ser positivos"
    FinSi
FinFuncion

Funcion parImpar(num1)
    Si num1 mod 2 = 0
        Escribir num1," Es par"
    SiNo
        Escribir num1, " Es impar"
    FinSi
FinFuncion

Funcion mayorMenorEdad(edad)
    Si edad >= 18 Entonces
        Escribir "La persona tiene ", edad, " Anos. [span_1](start_span)Es MAYOR de edad."[span_1](end_span)
    SiNo
        Si edad > 0 Entonces
            [span_2](start_span)Escribir "La persona tiene ", edad, " Anos. Es MENOR de edad."[span_2](end_span)
        SiNo
            [span_3](start_span)Escribir "Edad no valida."[span_3](end_span)
        FinSi
    [span_4](start_span)FinSi[span_4](end_span)
FinFuncion

Funcion compararDosNumeros(n1, n2)
    Si n1 > n2 Entonces
        Escribir "El numero mayor es: ", n1
    SiNo
        Si n2 > n1 Entonces
            Escribir "El numero mayor es: ", n2
        SiNo
            Escribir "Ambos numeros son iguales: ", n1, " = ", n2
        FinSi
    [span_5](start_span)FinSi[span_5](end_span)
FinFuncion

Funcion compararTresNumeros(n1, n2, n3)
    Si n1 > n2 Y n1 > n3 Entonces
        Escribir "El numero mayor de los tres es: ", n1
    SiNo
        Si n2 > n1 Y n2 > n3 Entonces
            Escribir "El numero mayor de los tres es: ", n2
        SiNo
            [span_6](start_span)Si n3 > n1 Y n3 > n2 Entonces[span_6](end_span)
                Escribir "El numero mayor de los tres es: ", n3
            SiNo
                Escribir "Hay numeros iguales o todos son iguales."
            [span_7](start_span)FinSi[span_7](end_span)
        FinSi
    FinSi
FinFuncion

Funcion calcularDescuentoCompra(monto)
    Definir descuento, totalPagar Como Real
    Si monto > 100 Entonces
        descuento = monto * 0.10 
        totalPagar = monto - descuento
        Escribir "Monto: $", monto
        Escribir "Aplica 10% de Descuento: $", descuento
        [span_8](start_span)Escribir "Total Neto a Pagar: $", totalPagar[span_8](end_span)
    SiNo
        Escribir "Monto: $", monto
        Escribir "No aplica descuento. Total a Pagar: $", monto
    FinSi
FinFuncion

